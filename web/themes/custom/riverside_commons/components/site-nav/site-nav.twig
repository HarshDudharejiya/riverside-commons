<header class="site-nav">
  <a href="/" class="site-nav__brand">Riverside Commons</a>

  <button
    type="button"
    class="site-nav__toggle"
    aria-expanded="false"
    aria-controls="site-nav-menu"
  >
    <span class="visually-hidden">Menu</span>
    <span class="site-nav__toggle-icon" aria-hidden="true"></span>
  </button>

  <nav id="site-nav-menu" class="site-nav__menu" aria-label="Main" hidden>
    <ul>
      {% for link in links %}
        <li><a href="{{ link.url }}">{{ link.text }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  {% if donate_url %}
    <a href="{{ donate_url }}" class="site-nav__cta">{{ donate_text|default('Donate') }}</a>
  {% endif %}
</header>
